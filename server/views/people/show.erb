<% profile_map_trips = @account.trips_dataset.published.exclude(lat: nil).exclude(lng: nil).reverse_order(:hiked_at).all %>
<% profile_map_points = profile_map_trips.map { |trip| {lat: trip.lat, lng: trip.lng, title: trip.name, url: trip.public_path} } %>
<% trip_count = @trips.size %>
<% trip_label = trip_count == 1 ? "trip" : "trips" %>
<% total_miles = @trips.sum { |trip| trip.mileage.to_f } %>
<% total_nights = @trips.sum { |trip| trip.nights.to_i } %>
<% night_label = total_nights == 1 ? "night out" : "nights out" %>
<% profile_years = @trip_years || ([@year] + @other_years).uniq.sort.reverse %>
<% follow_modal_open = @follow_errors && !@follow_errors.empty? %>

<% unless profile_map_points.empty? %>
  <section class="map-band profile-map-band" aria-label="<%= h(@account.name) %> trip map">
    <div class="map-panel site-map profile-map" data-map-collection data-map-expandable data-tile-url="<%= h(leaflet_tile_url) %>" data-points="<%= h(json(profile_map_points)) %>"></div>
  </section>
<% end %>

<section class="profile-header <%= "profile-header-with-map" unless profile_map_points.empty? %>">
  <div class="profile-avatar">
    <% if (avatar = avatar_url(@account, "medium")) %>
      <img class="avatar" src="<%= h(avatar) %>" alt="">
    <% else %>
      <span><%= h(@account.name.to_s[0].to_s.upcase) %></span>
    <% end %>
  </div>
  <div class="profile-summary">
    <h1><%= h(@account.name) %></h1>
    <% if @account.location %>
      <p class="lede"><%= h(@account.location) %></p>
    <% end %>
    <div class="kicker inline-kicker profile-stats">
      <span><%= h(format_number(trip_count)) %> <%= h(trip_label) %></span>
      <% if total_miles.positive? %>
        <span><%= h(format_number(total_miles, precision: 1)) %> miles logged</span>
      <% end %>
      <% if total_nights.positive? %>
        <span><%= h(format_number(total_nights)) %> <%= h(night_label) %></span>
      <% end %>
      <% if profile_years.size > 1 %>
        <form class="profile-year-form" action="<%= h(@account.public_path) %>" method="get">
          <label class="visually-hidden" for="profile-year">Trip year</label>
          <span>in</span>
          <select id="profile-year" class="profile-year-select" name="year" data-year-switcher>
            <% profile_years.each do |year| %>
              <option value="<%= h(year) %>" <%= "selected" if year == @year %>><%= h(year) %></option>
            <% end %>
          </select>
        </form>
      <% else %>
        <span class="profile-year-label">in <%= h(@year) %></span>
      <% end %>
      <span><a class="profile-subscribe-link" href="#profile-follow-modal" data-profile-modal-open="profile-follow-modal">Subscribe to updates</a></span>
    </div>
    <% if @follow_notice %>
      <p class="profile-follow-notice"><%= h(@follow_notice) %></p>
    <% end %>
  </div>
</section>

<div id="profile-follow-modal" class="profile-follow-modal<%= " is-open" if follow_modal_open %>" role="dialog" aria-modal="true" aria-labelledby="profile-follow-title" data-profile-follow-modal>
  <a class="profile-modal-backdrop" href="#" aria-label="Close subscribe form" data-profile-modal-close></a>
  <section class="profile-modal-panel" tabindex="-1">
    <a class="profile-modal-close" href="#" aria-label="Close subscribe form" data-profile-modal-close>&times;</a>
    <p class="kicker">Email updates</p>
    <h2 id="profile-follow-title">Subscribe to <%= h(first_name(@account)) %>'s hikes</h2>
    <form class="profile-follow-form" action="<%= h(@account.public_path) %>/follow" method="post">
      <% if @follow_errors && !@follow_errors.empty? %>
        <div class="profile-follow-errors" role="alert">
          <% @follow_errors.each do |error| %>
            <p><%= h(error) %></p>
          <% end %>
        </div>
      <% end %>
      <label for="follow-email">Email address</label>
      <div class="profile-follow-controls">
        <input id="follow-email" name="email" type="email" autocomplete="email" placeholder="you@example.com" value="<%= h(@follow_email) %>" required>
        <button type="submit">Subscribe</button>
      </div>
      <p class="inline-hints">Morning-after emails. Confirmation required.</p>
      <div class="honey-field" aria-hidden="true">
        <label for="follow-company">Company</label>
        <input id="follow-company" name="company" tabindex="-1" autocomplete="off">
      </div>
    </form>
  </section>
</div>

<section class="section profile-trips-section">
  <% if @trips.empty? %>
    <p class="empty">No hikes logged for this year yet.</p>
  <% else %>
    <div class="trip-list profile-trip-list">
      <% @trips.each do |trip| %>
        <% photos = trip.photos_dataset.order(:taken_at, :id).all %>
        <% trip_excerpt = trip.report_markdown.to_s.gsub(PHOTO_HANDLE_PATTERN, " ").gsub(/\s+/, " ").strip %>
        <article class="trip-row profile-trip-row" <%= %(data-photo-lightbox-gallery data-photo-lightbox-items="#{h(json(photo_lightbox_items(photos)))}") unless photos.empty? %>>
          <div class="profile-trip-content">
            <p class="meta"><%= h(trip_date_label(trip)) %></p>
            <div class="trip-row-heading">
              <h2><a href="<%= h(trip.public_path) %>"><%= h(trip.name) %></a></h2>
              <%= heart_button(trip, compact: true) %>
            </div>
            <p class="profile-trip-stats"><%= [number_label(trip.mileage, "miles"), number_label(trip.elevation, "feet gained"), night_count_label(trip.nights)].compact.join(" / ") %></p>
            <% unless trip_excerpt.empty? %>
              <p class="profile-trip-excerpt"><%= h(trip_excerpt[0, 360]) %><%= "..." if trip_excerpt.length > 360 %></p>
            <% end %>
          </div>
          <% if photos.any? %>
            <%= trip_photo_gallery_html(photos.first(6), all_photos: photos) %>
          <% elsif trip.lat && trip.lng %>
            <div class="profile-trip-map" data-static-map data-lat="<%= h(trip.lat) %>" data-lng="<%= h(trip.lng) %>" data-title="<%= h(trip.name) %>" data-tile-url="<%= h(leaflet_tile_url) %>" aria-hidden="true"></div>
          <% end %>
        </article>
      <% end %>
    </div>
  <% end %>
</section>
