<section class="photo-gallery-page">
  <p class="breadcrumbs"><a href="<%= h(@trip.public_path) %>">Back to <%= h(@trip.name) %></a></p>
  <header class="gallery-header">
    <p class="kicker">Trail Photos</p>
    <h1>Photos from <%= h(@trip.name) %></h1>
    <p class="lede"><%= h(trip_date_label(@trip)) %></p>
  </header>

  <% if @photos.empty? %>
    <p class="empty">No photos yet. Time to bring back proof of the views.</p>
  <% else %>
    <div class="photo-gallery" data-photo-lightbox-gallery data-photo-lightbox-items="<%= h(json(photo_lightbox_items(@photos))) %>">
      <% @photos.each_with_index do |photo, index| %>
        <a href="<%= h(photo.public_path) %>" data-photo-lightbox-trigger data-photo-index="<%= h(index) %>">
          <img src="<%= h(image_url(photo, "large")) %>" alt="<%= h(photo.caption) %>">
          <% if photo.caption %>
            <span><%= h(photo.caption) %></span>
          <% end %>
        </a>
      <% end %>
    </div>
  <% end %>
</section>
