<section class="form-page">
  <p class="breadcrumbs"><a href="<%= h(@trip.public_path) %>">Back to <%= h(@trip.name) %></a></p>
  <header class="form-header">
    <p class="kicker">Photos</p>
    <h1>Add Trail Photos</h1>
    <p class="lede">Bring back the good light from <%= h(@trip.name) %>.</p>
  </header>

  <% unless @photo_errors.empty? %>
    <div class="form-errors" role="alert">
      <p>A couple things need fixing before these can hit the gallery:</p>
      <ul>
        <% @photo_errors.each do |error| %>
          <li><%= h(error) %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <form class="photo-form" action="<%= h(@trip.public_path) %>/photos" method="post" enctype="multipart/form-data">
    <div class="form-grid">
      <div class="form-row form-row-full">
        <label for="photo-image">Image</label>
        <input id="photo-image" name="image" type="file" accept="image/jpeg,image/png,image/gif" required>
      </div>

      <div class="form-row form-row-full">
        <label for="photo-caption">Caption</label>
        <textarea id="photo-caption" name="caption" rows="4"></textarea>
      </div>
    </div>

    <div class="form-actions">
      <button type="submit">Upload photo</button>
      <a href="<%= h(@trip.public_path) %>">Cancel</a>
    </div>
  </form>
</section>
