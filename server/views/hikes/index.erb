<section class="section">
  <p class="kicker"><%= h(@kicker || "Explore") %></p>
  <h1><%= h(@heading || "Recent Hikes") %></h1>
  <form class="search-form" action="/search" method="get">
    <label for="hike-search">Search hikes</label>
    <div class="search-row">
      <input id="hike-search" name="q" value="<%= h(@query) %>">
      <button type="submit">Search</button>
    </div>
  </form>
  <% if @trips.empty? %>
    <p class="empty">No hikes match that search yet. Try another peak, lake, or trail name.</p>
  <% else %>
    <div class="trip-list">
      <% @trips.each do |trip| %>
        <article class="trip-row">
          <p class="meta"><%= h(date_label(trip.hiked_at)) %> · <%= h(trip.account.name) %></p>
          <h2><a href="<%= h(trip.public_path) %>"><%= h(trip.name) %></a></h2>
          <p><%= [number_label(trip.mileage, "miles"), number_label(trip.elevation, "feet gained"), (trip.nights.to_i.positive? ? "#{trip.nights} nights" : nil)].compact.join(" · ") %></p>
        </article>
      <% end %>
    </div>
  <% end %>
</section>
