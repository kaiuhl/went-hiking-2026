<section class="section hike-index-section">
  <div class="section-heading">
    <h1><%= h(@heading || "Recent Hikes") %></h1>
    <% unless @trips.empty? %>
      <span class="meta">Showing <%= h(format_number(@trips.size)) %></span>
    <% end %>
  </div>
  <form class="search-form" action="/search" method="get">
    <label for="hike-search">Search hikes</label>
    <div class="search-row">
      <input id="hike-search" name="q" value="<%= h(@query) %>">
      <button type="submit">Search</button>
    </div>
  </form>
  <%= render("hikes/trip_list", locals: {trips: @trips, empty_message: "No hikes match that search yet. Try another peak, lake, or trail name."}) %>
</section>
