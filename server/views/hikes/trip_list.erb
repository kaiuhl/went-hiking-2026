<% if trips.empty? %>
  <p class="empty"><%= h(empty_message) %></p>
<% else %>
  <div class="trip-list home-trip-list">
    <% trips.each do |trip| %>
      <% photos = trip.photos_dataset.order(:taken_at, :id).all %>
      <% trip_excerpt = trip.report_markdown.to_s.gsub(PHOTO_HANDLE_PATTERN, " ").gsub(/\s+/, " ").strip %>
      <article class="trip-row home-trip-row" <%= %(data-photo-lightbox-gallery data-photo-lightbox-items="#{h(json(photo_lightbox_items(photos)))}") unless photos.empty? %>>
        <div class="home-trip-content">
          <p class="meta"><%= h(date_label(trip.hiked_at)) %> / <a href="<%= h(trip.account.public_path) %>"><%= h(trip.account.name) %></a></p>
          <div class="trip-row-heading">
            <h3><a href="<%= h(trip.public_path) %>"><%= h(trip.name) %></a></h3>
            <%= heart_button(trip, compact: true) %>
          </div>
          <p class="home-trip-stats"><%= [number_label(trip.mileage, "miles"), number_label(trip.elevation, "feet gained"), night_count_label(trip.nights)].compact.join(" / ") %></p>
          <% unless trip_excerpt.empty? %>
            <p class="home-trip-excerpt"><%= h(trip_excerpt[0, 360]) %><%= "..." if trip_excerpt.length > 360 %></p>
          <% end %>
        </div>
        <% if photos.any? %>
          <%= trip_photo_gallery_html(photos.first(6), all_photos: photos) %>
        <% elsif trip.lat && trip.lng %>
          <div class="home-trip-map" data-static-map data-lat="<%= h(trip.lat) %>" data-lng="<%= h(trip.lng) %>" data-title="<%= h(trip.name) %>" data-tile-url="<%= h(leaflet_tile_url) %>" aria-hidden="true"></div>
        <% end %>
      </article>
    <% end %>
  </div>
<% end %>
