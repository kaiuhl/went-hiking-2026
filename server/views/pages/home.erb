<section class="home-hero">
  <p class="kicker">Hike it. Map it. Tell the story.</p>
  <h1>Went Hiking</h1>
  <p class="lede">Log the miles, share the photos, and discover where everyone is heading next.</p>
</section>

<% if @archive_stats[:trips].positive? %>
  <section class="section archive-overview">
    <div class="stat-grid" aria-label="Community totals">
      <div>
        <span><%= h(format_number(@archive_stats[:trips])) %></span>
        <p>Trips</p>
      </div>
      <div>
        <span><%= h(format_number(@archive_stats[:photos])) %></span>
        <p>Photos</p>
      </div>
      <div>
        <span><%= h(format_number(@archive_stats[:miles], precision: 1)) %></span>
        <p>Miles logged</p>
      </div>
      <div>
        <span><%= h(format_number(@archive_stats[:nights])) %></span>
        <p>Nights out</p>
      </div>
    </div>

    <% unless @map_points.empty? %>
      <div class="map-panel home-map" data-map-collection data-tile-url="<%= h(leaflet_tile_url) %>" data-points="<%= h(json(@map_points.map { |trip| {lat: trip.lat, lng: trip.lng, title: trip.name, url: trip.public_path} })) %>"></div>
    <% end %>
  </section>
<% end %>

<section class="section">
  <div class="section-heading">
    <h2>Recent Hikes</h2>
    <a href="/hikes">View all</a>
  </div>
  <% if @recent_trips.empty? %>
    <p class="empty">No hikes yet. Be the first to get one on the map.</p>
  <% else %>
    <div class="trip-grid">
      <% @recent_trips.each do |trip| %>
        <article class="trip-card">
          <% photo = trip.photos_dataset.first %>
          <% if photo %>
            <a href="<%= h(trip.public_path) %>"><img src="<%= h(image_url(photo, "large")) %>" alt=""></a>
          <% end %>
          <p class="meta"><%= h(date_label(trip.hiked_at)) %></p>
          <h3><a href="<%= h(trip.public_path) %>"><%= h(trip.name) %></a></h3>
          <p><%= h(trip.account.name) %></p>
        </article>
      <% end %>
    </div>
  <% end %>
</section>

<% if @archive_stats[:trips].positive? %>
  <section class="section leaderboard-section">
    <div class="section-heading">
      <h2><%= h(Date.today.year) %> Leaders</h2>
      <span class="meta">This year's trail bragging rights</span>
    </div>

    <div class="leaderboard-grid">
      <section>
        <h3>Mileage</h3>
        <ol class="leaderboard-list">
          <% @leaderboards[:mileage].each do |entry| %>
            <li>
              <a href="<%= h(entry[:account].public_path) %>"><%= h(entry[:account].name) %></a>
              <span><%= h(format_number(entry[:value], precision: 1)) %> mi</span>
            </li>
          <% end %>
        </ol>
      </section>

      <section>
        <h3>Elevation</h3>
        <ol class="leaderboard-list">
          <% @leaderboards[:elevation].each do |entry| %>
            <li>
              <a href="<%= h(entry[:account].public_path) %>"><%= h(entry[:account].name) %></a>
              <span><%= h(format_number(entry[:value])) %> ft</span>
            </li>
          <% end %>
        </ol>
      </section>

      <section>
        <h3>Nights</h3>
        <ol class="leaderboard-list">
          <% @leaderboards[:nights].each do |entry| %>
            <li>
              <a href="<%= h(entry[:account].public_path) %>"><%= h(entry[:account].name) %></a>
              <span><%= h(format_number(entry[:value])) %></span>
            </li>
          <% end %>
        </ol>
      </section>
    </div>
  </section>

  <section class="section">
    <div class="section-heading">
      <h2>Newest Members</h2>
    </div>
    <div class="member-list">
      <% @newest_members.each do |account| %>
        <a href="<%= h(account.public_path) %>">
          <% if (avatar = avatar_url(account, "micro")) %>
            <img src="<%= h(avatar) %>" alt="">
          <% end %>
          <span><%= h(account.name) %></span>
        </a>
      <% end %>
    </div>
  </section>
<% end %>
