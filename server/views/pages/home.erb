<% home_map_points = @map_points.map { |trip| {lat: trip.lat, lng: trip.lng, title: trip.name, url: trip.public_path} } %>
<% trip_label = @archive_stats[:trips] == 1 ? "trip" : "trips" %>
<% photo_label = @archive_stats[:photos] == 1 ? "photo" : "photos" %>
<% night_label = @archive_stats[:nights] == 1 ? "night out" : "nights out" %>
<% unless home_map_points.empty? %>
  <section class="map-band home-map-band" aria-label="Trip map">
    <div class="map-panel site-map home-map" data-map-collection data-map-expandable data-tile-url="<%= h(leaflet_tile_url) %>" data-points="<%= h(json(home_map_points)) %>"></div>
  </section>
<% end %>

<section class="home-hero">
  <p class="kicker inline-kicker home-kicker">
    <% if @archive_stats[:trips].positive? %>
      <span><%= h(format_number(@archive_stats[:trips])) %> <%= h(trip_label) %></span>
      <span><%= h(format_number(@archive_stats[:photos])) %> <%= h(photo_label) %></span>
      <span><%= h(format_number(@archive_stats[:miles], precision: 1)) %> miles logged</span>
      <span><%= h(format_number(@archive_stats[:nights])) %> <%= h(night_label) %></span>
    <% end %>
    <span class="home-kicker-since">since 2010</span>
  </p>
  <p class="lede">A tool for recording your trips into the wilderness and discovering new ones. Join the hundreds of people recording their stories from the trail.</p>
</section>

<section class="section">
  <div class="section-heading">
    <h2>Recent Hikes</h2>
    <a href="/hikes">View all</a>
  </div>
  <%= render("hikes/trip_list", locals: {trips: @recent_trips, empty_message: "No hikes yet. Be the first to get one on the map."}) %>
</section>

<% if @archive_stats[:trips].positive? %>
  <section class="section leaderboard-section">
    <div class="section-heading">
      <h2><%= h(Date.today.year) %> Leaders</h2>
      <span class="meta">This year's trail bragging rights</span>
    </div>

    <div class="leaderboard-grid">
      <section>
        <h3>Mileage</h3>
        <ol class="leaderboard-list">
          <% @leaderboards[:mileage].each do |entry| %>
            <li>
              <a href="<%= h(entry[:account].public_path) %>"><%= h(entry[:account].name) %></a>
              <span><%= h(format_number(entry[:value], precision: 1)) %> mi</span>
            </li>
          <% end %>
        </ol>
      </section>

      <section>
        <h3>Elevation</h3>
        <ol class="leaderboard-list">
          <% @leaderboards[:elevation].each do |entry| %>
            <li>
              <a href="<%= h(entry[:account].public_path) %>"><%= h(entry[:account].name) %></a>
              <span><%= h(format_number(entry[:value])) %> ft</span>
            </li>
          <% end %>
        </ol>
      </section>

      <section>
        <h3>Nights</h3>
        <ol class="leaderboard-list">
          <% @leaderboards[:nights].each do |entry| %>
            <li>
              <a href="<%= h(entry[:account].public_path) %>"><%= h(entry[:account].name) %></a>
              <span><%= h(format_number(entry[:value])) %></span>
            </li>
          <% end %>
        </ol>
      </section>
    </div>
  </section>

  <section class="section">
    <div class="section-heading">
      <h2>Newest Members</h2>
    </div>
    <div class="member-list">
      <% @newest_members.each do |account| %>
        <a href="<%= h(account.public_path) %>">
          <% if (avatar = avatar_url(account, "micro")) %>
            <img src="<%= h(avatar) %>" alt="">
          <% end %>
          <span><%= h(account.name) %></span>
        </a>
      <% end %>
    </div>
  </section>
<% end %>
