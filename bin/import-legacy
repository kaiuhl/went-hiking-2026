#!/usr/bin/env ruby
# frozen_string_literal: true

require_relative "../config/boot"
require "went_hiking/import/archive_source"
require "went_hiking/import/runner"

source = if ENV["LEGACY_ARCHIVE_PATH"]
  WentHiking::Import::ArchiveSource.new(ENV.fetch("LEGACY_ARCHIVE_PATH"))
else
  source_url = ENV.fetch("LEGACY_DATABASE_URL") do
    abort "Set LEGACY_DATABASE_URL to the loaded legacy MySQL database URL or LEGACY_ARCHIVE_PATH to an exported legacy archive"
  end
  Sequel.connect(source_url)
end

summary = WentHiking::Import::Runner.new(source_db: source).run
puts JSON.pretty_generate(summary)
